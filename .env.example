# ──────────────────────────────────────────────────────────────
# JUAN MECÁNICO — Variables de Entorno
# ──────────────────────────────────────────────────────────────

# ── TWILIO WhatsApp ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886
WEBHOOK_URL=https://us-central1-your-project.cloudfunctions.net/handleWhatsApp

# ── GOOGLE CLOUD ──────────────────────────────────────────────
GOOGLE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com

# ── GEMINI API ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ── CONFIG BOT ────────────────────────────────────────────────
BOT_NOMBRE=Juan Mecánico
PRIVACY_URL=https://example.com/politica-privacidad.html
PRIVACY_VERSION=1.0
MAX_FALLAS_ANTES_ALERTA=3
RATE_LIMIT_POR_HORA=15

# ── ADMIN ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
